```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temp files
*.tmp

# Build outputs
dist/
build/
target/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage reports
coverage/
htmlcov/
.coverage

# Local configuration
.env*
!.env.example
!.env.defaults
```