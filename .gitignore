.coverage
htmlcov/
.coverage.*
.nyc_output/
coverage-final.json

# Distribution / packaging
*.tar.gz
*.whl
*.zip

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pytest
.pytest_cache/

# Coverage
.coverage
htmlcov/

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Compressed files
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
