.python-version

# Build outputs
dist/
build/
*.egg-info/
.eggs/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated
.DS_Store
Thumbs.db

